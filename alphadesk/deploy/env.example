# AlphaDesk VM configuration — copy to repo root as .env and fill in. chmod 600 .env
# ──────────────────────────────────────────────────────────────────────────────

# Claude Max subscription (generate on your Mac: `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN=

# Market data (free tiers)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
POLYGON_API_KEY=

# Knowledge graph — Neo4j Aura Free (console.neo4j.io)
NEO4J_URI=neo4j+s://XXXXXXXX.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Dashboard (Basic Auth — REQUIRED, the app fails closed without them)
ADMIN_USERNAME=
ADMIN_PASSWORD=
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Optional model overrides, e.g.: MODEL_ARBITER=sonnet
# IMPORTANT: do NOT set ANTHROPIC_API_KEY here — it would bill the API instead
# of the Max subscription.
